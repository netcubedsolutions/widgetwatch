---
import { hubOrder, hubNavLabels, hubs } from '../../data/hubs.js';

const hubSummaries: Record<string, { name: string; city: string; subtitle: string; iata: string }> = {};
for (const key of hubOrder) {
  const h = hubs[key];
  hubSummaries[key] = {
    name: h.airportSchema.name,
    city: h.airportSchema.addressLocality,
    subtitle: h.subtitle,
    iata: h.iata,
  };
}
---
